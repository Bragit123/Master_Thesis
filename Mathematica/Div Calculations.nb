          RowBox[{"2", "Pi"}], ")"}], "^", 
         RowBox[{"(", 
          RowBox[{"4", "-", "D"}], ")"}]}]}]}], "]"}], "&"}]}], "//", 
   "FCHideEpsilon"}], "//", 
  RowBox[{
   RowBox[{"Collect2", "[", 
