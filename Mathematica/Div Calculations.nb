Cell["\<\
Extract the divergent parts of C0, but keeping the finite parts unevaluated\
\>", "Text",
 CellChangeTimes->{{3.980248546861805*^9, 
  3.9802485764625196`*^9}},ExpressionUUID->"35ea8c15-04b7-4cfd-af06-\
aac500610b97"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"C0UV", "=", 
  RowBox[{
   RowBox[{"C0", "[", 
    RowBox[{
     RowBox[{"m1", "^", "2"}], ",", 
     RowBox[{"m2", "^", "2"}], ",", 
     RowBox[{"Q", "^", "2"}], ",", 
     RowBox[{"m1", "^", "2"}], ",", "0", ",", 
     RowBox[{"m2", "^", "2"}]}], "]"}], "//", 
   "PaXEvaluateUV"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"C0IR", "[", "0", "]"}], "=", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       RowBox[{
        RowBox[{"C0", "[", 
         RowBox[{
          RowBox[{"m1", "^", "2"}], ",", 
          RowBox[{"m2", "^", "2"}], ",", 
          RowBox[{"Q", "^", "2"}], ",", 
          RowBox[{"m1", "^", "2"}], ",", "0", ",", 
          RowBox[{"m2", "^", "2"}]}], "]"}], "//", "PaXEvaluateIR"}], "//", 
       "FCHideEpsilon"}], ")"}], "[", 
     RowBox[{"[", "2", "]"}], "]"}], "//", 
    RowBox[{
     RowBox[{"ReplaceRepeated", "[", 
      RowBox[{"#", ",", 
       RowBox[{"Join", "[", 
        RowBox[{"\[Lambda]Rules", ",", "dimLessRules"}], "]"}]}], "]"}], 
     "&"}]}], "//", "FullSimplify"}]}], "\[IndentingNewLine]", 
 RowBox[{"Cpart", "=", 
  RowBox[{
   RowBox[{"(", 
    RowBox[{
     RowBox[{"KK", "[", "1463", "]"}], "//", "FRH"}], ")"}], 
   RowBox[{"(", 
    RowBox[{
     RowBox[{"C0IR", "[", "0", "]"}], "+", "Cfinite"}], ")"}]}]}]}], "Input",
 CellChangeTimes->{{3.980248340523776*^9, 3.980248365835122*^9}, {
  3.980248398622549*^9, 3.980248538908504*^9}, {3.9802486240825567`*^9, 
