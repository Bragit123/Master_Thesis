Cell[BoxData[
 RowBox[{
  RowBox[{"f", "[", "2", "]"}], "=", 
  RowBox[{
   RowBox[{
    RowBox[{"-", 
     RowBox[{
      RowBox[{"SMP", "[", "\"\<e\>\"", "]"}], "^", "2"}]}], "/", 
    RowBox[{"(", 
     RowBox[{"8", 
      RowBox[{"Pi", "^", "2"}]}], ")"}]}], 
   RowBox[{"(", 
    RowBox[{
     RowBox[{"Cpart", "+", "nonCpart"}], "//", 
     RowBox[{
      RowBox[{"Collect2", "[", 
       RowBox[{"#", ",", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"SMP", "[", "\"\<Delta_IR\>\"", "]"}], ",", 
          RowBox[{"SMP", "[", "\"\<Delta_UV\>\"", "]"}]}], "}"}], ",", 
        RowBox[{"Factoring", "->", "FullSimplify"}]}], "]"}], "&"}]}], 
    ")"}]}]}]], "Input",
