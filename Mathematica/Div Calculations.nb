            SqrtBox[
             SubscriptBox["\[Lambda]", "z"]], "-", "z"}], 
           RowBox[{"2", " ", 
            SqrtBox[
             RowBox[{
              SubscriptBox["\[Beta]", "1"], " ", 
              SubscriptBox["\[Beta]", "2"]}]]}]], ")"}]}], 
        SqrtBox[
         SubscriptBox["\[Lambda]", "z"]]], "+", 
       RowBox[{"log", "(", 
        SuperscriptBox["\[Mu]", "2"], ")"}], "-", 
       RowBox[{
        FractionBox["1", "2"], " ", 
        RowBox[{"log", "(", 
         RowBox[{
          SubscriptBox["\[Beta]", "1"], " ", 
