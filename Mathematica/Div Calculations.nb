          RowBox[{
           RowBox[{"{", 
            RowBox[{"k", ",", "m1"}], "}"}], ",", 
           RowBox[{"k", "+", "k1"}], ",", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"k", "+", "k1", "+", "k2"}], ",", "m2"}], "}"}]}], 
          "]"}]}], "//", 
