Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"diags", "=", 
   RowBox[{"InsertFields", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"CreateTopologies", "[", 
      RowBox[{"0", ",", 
       RowBox[{"1", "->", "3"}]}], "]"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"V", "[", "1", "]"}], "}"}], "->", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"-", 
         RowBox[{"S", "[", 
          RowBox[{"12", ",", 
           RowBox[{"{", 
            RowBox[{"B", ",", "i"}], "}"}]}], "]"}]}], ",", 
        RowBox[{"V", "[", "1", "]"}], ",", 
        RowBox[{"S", "[", 
         RowBox[{"12", ",", 
          RowBox[{"{", 
           RowBox[{"A", ",", "i"}], "}"}]}], "]"}]}], "}"}]}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"Model", "->", "MSSM"}], ",", "\[IndentingNewLine]", 
     RowBox[{"InsertionLevel", "->", 
      RowBox[{"{", "Classes", "}"}]}]}], "\[IndentingNewLine]", "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
