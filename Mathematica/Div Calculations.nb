  RowBox[{"-", 
   RowBox[{
    FractionBox["1", 
     RowBox[{"8", " ", 
      SuperscriptBox["\[Pi]", "2"]}]], 
    RowBox[{
     SuperscriptBox["\<\"e\"\>", "2"], " ", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"s", " ", 
        SubscriptBox["C", "finite"], " ", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"-", 
