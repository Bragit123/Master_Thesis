Cell[TextData[{
 "Base for all D-type Passarino-Veltman tensor functions, to be multiplied \
with ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["k", "TI"], 
          SubscriptBox["\[Mu]", "1"]], "\[Ellipsis]", 
         SubscriptBox[
          StyleBox["k", "TI"], 
          SubscriptBox["\[Mu]", 
           StyleBox["n", "TI"]]]}], TraditionalForm], "errors" -> {}, "input" -> 
     "k_{\\mu_1}\\ldots k_{\\mu_n}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "28c3b4c3-e4a1-459c-8379-ceeecc9ce01d"],
