Cell[BoxData[
 RowBox[{"Dbase", "=", 
  RowBox[{
   RowBox[{"FAD", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"k", ",", "\[Mu]Z\[Gamma]"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"k", "+", "p1"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"k", "+", "p1", "+", "p2"}], ",", "\[Mu]\[Gamma]Z"}], "}"}], 
     ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"k", "+", "k1"}], ",", "m"}], "}"}]}], "]"}], "/", 
   RowBox[{"(", 
    RowBox[{"I", " ", 
     RowBox[{"Pi", "^", "2"}]}], ")"}]}]}]], "Input",
