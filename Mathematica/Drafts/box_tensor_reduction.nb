Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"QuickD", "[", "indices_", "]"}], ":=", 
   RowBox[{"PaVe", "@@", 
    RowBox[{"(", 
     RowBox[{"Join", "[", 
      RowBox[{"indices", ",", 
       RowBox[{"{", 
        RowBox[{"DargMom", ",", "DargMass"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"PaVeAutoOrder", "->", "False"}], ",", 
         RowBox[{"PaVeAutoReduce", "->", "True"}]}], "}"}]}], "]"}], 
     ")"}]}]}], ";"}]], "Input",
 CellChangeTimes->{{3.983698855927615*^9, 3.983698882406399*^9}, {
