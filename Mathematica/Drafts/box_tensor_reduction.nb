Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"QuickD", "[", "indices_", "]"}], ":=", 
   RowBox[{"PaVe", "@@", 
    RowBox[{"(", 
     RowBox[{"Join", "[", 
      RowBox[{"indices", ",", 
       RowBox[{"{", 
        RowBox[{"DargMom", ",", "DargMass"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"PaVeAutoOrder", "->", "False"}], ",", 
         RowBox[{"PaVeAutoReduce", "->", "True"}]}], "}"}]}], "]"}], 
     ")"}]}]}], ";"}]], "Input",
