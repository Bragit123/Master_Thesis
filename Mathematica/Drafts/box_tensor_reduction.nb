Cell[TextData[{
 StyleBox["WARNING:",
  FontWeight->"Bold"],
 " ",
 "With the argument convention chosen here (DargMom and DargMass) the tensor \
expansion becomes ",
 Cell[BoxData[
  FormBox[
   RowBox[{" ", 
    TemplateBox[<|"boxes" -> FormBox[
        RowBox[{
          SubscriptBox[
           StyleBox["D", "TI"], "\[Mu]"], "\[LongEqual]", 
          SubsuperscriptBox[
           StyleBox["p", "TI"], "1", "\[Mu]"], 
          SubscriptBox[
           StyleBox["D", "TI"], "1"], "+", 
          SuperscriptBox[
           RowBox[{"(", 
             RowBox[{
               SubscriptBox[
                StyleBox["p", "TI"], "1"], "+", 
               SubscriptBox[
                StyleBox["p", "TI"], "2"]}], ")"}], "\[Mu]"], 
          SubscriptBox[
           StyleBox["D", "TI"], "2"], "+", 
          SubsuperscriptBox[
           StyleBox["k", "TI"], "1", "\[Mu]"], 
          SubscriptBox[
           StyleBox["D", "TI"], "3"]}], TraditionalForm], "errors" -> {}, 
      "input" -> "D_\\mu = p_1^\\mu D_1 + (p_1+p_2)^\\mu D_2 + k_1^\\mu D_3", 
      "state" -> "Boxes"|>,
     "TeXAssistantTemplate"]}], TraditionalForm]],ExpressionUUID->
  "83e2ac69-c91c-44b7-9b24-9f2cf4175b64"]
}], "Text",
