Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"FVD", "[", 
   RowBox[{"k", ",", "\[Mu]"}], "]"}], "Dbase"}], "\[IndentingNewLine]", 
 RowBox[{"D\[Mu]", "=", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"%", "//", 
      RowBox[{
       RowBox[{"TID", "[", 
        RowBox[{"#", ",", "k", ",", 
         RowBox[{"ToPaVe", "->", "True"}], ",", 
         RowBox[{"UsePaVeBasis", "->", "True"}], ",", 
         RowBox[{"PaVeAutoOrder", "->", "False"}], ",", 
         RowBox[{"PaVeAutoReduce", "->", "True"}]}], "]"}], "&"}]}], "//", 
     RowBox[{
      RowBox[{"TrickMandelstam", "[", 
       RowBox[{"#", ",", 
        RowBox[{"{", 
         RowBox[{"s", ",", "t", ",", "u", ",", 
          RowBox[{
           RowBox[{"m1", "^", "2"}], "+", 
           RowBox[{"m2", "^", "2"}]}]}], "}"}]}], "]"}], "&"}]}], "//", 
    "Simplify"}], "//", 
   RowBox[{
    RowBox[{"PaVeOrder", "[", 
     RowBox[{"#", ",", 
      RowBox[{"PaVeOrderList", "->", 
       RowBox[{"{", 
        RowBox[{"\[Mu]\[Gamma]Z", ",", "0", ",", "\[Mu]Z\[Gamma]", ",", "m"}],
         "}"}]}]}], "]"}], "&"}]}]}]}], "Input",
