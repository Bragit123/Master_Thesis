Cell[CellGroupData[{

Cell["LO diagrams to combine for interference terms", "Section",
 CellChangeTimes->{{3.9693667794353943`*^9, 
  3.9693667912574673`*^9}},ExpressionUUID->"5583d82b-69e3-490a-847c-\
231c5ee78c9c"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"diagsCT", "[", "0", "]"}], "=", 
   RowBox[{"InsertFields", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"CreateCTTopologies", "[", 
      RowBox[{"1", ",", 
       RowBox[{"2", "->", "2"}]}], "]"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"F", "[", 
         RowBox[{"3", ",", 
          RowBox[{"{", "quarkGen", "}"}]}], "]"}], ",", 
        RowBox[{"-", 
         RowBox[{"F", "[", 
          RowBox[{"3", ",", 
           RowBox[{"{", "quarkGen", "}"}]}], "]"}]}]}], "}"}], "->", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"-", 
         RowBox[{"S", "[", 
          RowBox[{"12", ",", 
           RowBox[{"{", 
            RowBox[{"B", ",", "i"}], "}"}]}], "]"}]}], ",", 
        RowBox[{"S", "[", 
         RowBox[{"12", ",", 
          RowBox[{"{", 
           RowBox[{"A", ",", "i"}], "}"}]}], "]"}]}], "}"}]}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"Model", "->", "MSSMCT"}], ",", "\[IndentingNewLine]", 
     RowBox[{"InsertionLevel", "->", 
      RowBox[{"{", "Classes", "}"}]}], ",", "\[IndentingNewLine]", 
     RowBox[{"ExcludeParticles", "->", 
      RowBox[{"{", 
       RowBox[{"S", "[", 
        RowBox[{"1", "|", "2", "|", "3", "|", "4"}], "]"}], "}"}]}]}], 
    "\[IndentingNewLine]", "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Paint", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"diagsCT", "[", "0", "]"}], ",", "\[IndentingNewLine]", 
    RowBox[{"ColumnsXRows", "->", 
     RowBox[{"{", 
      RowBox[{"4", ",", "2"}], "}"}]}], ",", "\[IndentingNewLine]", 
    RowBox[{"SheetHeader", "->", "None"}], ",", "\[IndentingNewLine]", 
    RowBox[{"Numbering", "->", "Simple"}], ",", "\[IndentingNewLine]", 
    RowBox[{"ImageSize", "->", 
     RowBox[{"{", 
      RowBox[{"512", ",", "256"}], "}"}]}]}], "\[IndentingNewLine]", "]"}], 
  ";"}]}], "Input",
 CellChangeTimes->{{3.979295042903658*^9, 3.97929504345039*^9}, {
