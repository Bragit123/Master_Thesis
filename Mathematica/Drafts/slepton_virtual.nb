Cell["\<\
Simplify by using momentum conservation and Dirac equation again to get rid \
of all \[Gamma].k2\[CloseCurlyQuote]s\
\>", "Text",
 CellChangeTimes->{{3.971180320103928*^9, 
  3.971180346650688*^9}},ExpressionUUID->"ff633cfc-584c-4ac9-9794-\
8ba9d1d89307"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"M1Z", "[", "3", "]"}], "=", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"M1Z", "[", "2", "]"}], "//", "DiracGammaExpand"}], "//", 
     RowBox[{
      RowBox[{"ReplaceAll", "[", 
       RowBox[{"#", ",", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"DiracGamma", "[", 
           RowBox[{
            RowBox[{"Momentum", "[", 
             RowBox[{"k2", ",", "D"}], "]"}], ",", "D"}], "]"}], "->", 
          RowBox[{"DiracGamma", "[", 
           RowBox[{
            RowBox[{"Momentum", "[", 
             RowBox[{
              RowBox[{"p1", "+", "p2", "-", "k1"}], ",", "D"}], "]"}], ",", 
            "D"}], "]"}]}], "}"}]}], "]"}], "&"}]}], "//", "DiracSimplify"}], 
   "//", "Simplify"}]}]], "Input",
 CellChangeTimes->{{3.971180161435691*^9, 3.971180184881287*^9}, {
  3.9711802388809032`*^9, 3.971180316564467*^9}, {3.971426411153521*^9, 
