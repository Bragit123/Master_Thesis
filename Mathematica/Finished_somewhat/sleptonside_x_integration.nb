 FormBox[
  TemplateBox[<|"boxes" -> FormBox[
      RowBox[{
        SubscriptBox[
         StyleBox["I", "TI"], "2"], "\[LongEqual]", 
        SubsuperscriptBox["\[Integral]", 
         SuperscriptBox[
          StyleBox["x", "TI"], "-"], 
         SuperscriptBox[
          StyleBox["x", "TI"], "+"]], 
        StyleBox["d", "TI"], 
        StyleBox["x", "TI"], " ", 
        FractionBox[
         RowBox[{
           RowBox[{"(", 
             RowBox[{
               SuperscriptBox[
                StyleBox["x", "TI"], "+"], "-", 
               StyleBox["x", "TI"]}], ")"}], "(", 
           RowBox[{
             StyleBox["x", "TI"], "-", 
             SuperscriptBox[
              StyleBox["x", "TI"], "-"]}], ")"}], 
         RowBox[{
           SuperscriptBox[
            RowBox[{"(", 
              RowBox[{"1", "+", 
                StyleBox["x", "TI"]}], ")"}], "2"], 
           SuperscriptBox[
            RowBox[{"(", 
              RowBox[{"1", "-", 
                StyleBox["x", "TI"]}], ")"}], "2"]}]], "ln", 
        RowBox[{"[", 
          RowBox[{
            RowBox[{"(", 
              RowBox[{
                SuperscriptBox[
                 StyleBox["x", "TI"], "+"], "-", 
                StyleBox["x", "TI"]}], ")"}], "(", 
            RowBox[{
              StyleBox["x", "TI"], "-", 
              SuperscriptBox[
               StyleBox["x", "TI"], "-"]}], ")"}], "]"}]}], TraditionalForm], 
    "errors" -> {}, "input" -> 
    "I_2 = \\int_{x^-}^{x^+}dx\\,\\frac{(x^+-x)(x-x^-)}{(1+x)^2(1-x)^2}\\ln[(\
x^+-x)(x-x^-)]", "state" -> "Boxes"|>,
   "TeXAssistantTemplate"], 
  TraditionalForm]],ExpressionUUID->"984b49b6-9fb0-402c-9f93-a53384e2fefe"]], \
