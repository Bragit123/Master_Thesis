Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"exprNum", "[", "1", "]"}], "=", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{
             RowBox[{
              RowBox[{
               RowBox[{"exprNum", "[", "0", "]"}], "//", "top1ki"}], "//", 
              "FullSimplify"}], "//", "pikikToxyz"}], "//", "FCE"}], "//", 
           RowBox[{
            RowBox[{"ReplaceAll", "[", 
             RowBox[{"#", ",", 
              RowBox[{"{", "\[IndentingNewLine]", 
               RowBox[{
                RowBox[{"SPD", "[", 
                 RowBox[{"k1", ",", "k2"}], "]"}], "->", 
                RowBox[{
                 RowBox[{"(", 
                  RowBox[{
                   RowBox[{"s", " ", "z"}], "-", 
                   RowBox[{"m1", "^", "2"}], "-", 
                   RowBox[{"m2", "^", "2"}]}], ")"}], "/", "2"}]}], 
               "\[IndentingNewLine]", "}"}]}], "]"}], "&"}]}], "//", 
          "FullSimplify"}], "//", "FRH"}], "//", "p1kiToyzPhi"}], "//", 
       "FullSimplify"}], "//", 
      RowBox[{
       RowBox[{"ReplaceAll", "[", 
        RowBox[{"#", ",", 
         RowBox[{"{", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"m1", "->", 
            RowBox[{
             RowBox[{"Sqrt", "[", 
              RowBox[{"s", " ", "z"}], "]"}], " ", "mt1"}]}], ",", 
           "\[IndentingNewLine]", 
           RowBox[{"m2", "->", 
            RowBox[{
             RowBox[{"Sqrt", "[", 
              RowBox[{"s", " ", "z"}], "]"}], " ", "mt2"}]}]}], 
          "\[IndentingNewLine]", "}"}]}], "]"}], "&"}]}], "//", 
     "FullSimplify"}], "//", "xyzSimplify"}], "//", 
   RowBox[{
    RowBox[{"Collect2", "[", 
     RowBox[{"#", ",", "\[CapitalPhi]", ",", 
      RowBox[{"Factoring", "->", "FullSimplify"}], ",", 
      RowBox[{"IsolateNames", "->", "KK"}]}], "]"}], "&"}]}]}]], "Input",
 CellChangeTimes->{{3.986875202420096*^9, 3.986875216330901*^9}, {
