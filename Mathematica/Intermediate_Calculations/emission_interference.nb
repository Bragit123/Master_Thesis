Cell[BoxData[
 RowBox[{
  RowBox[{"yint", "[", "0", "]"}], "=", 
  RowBox[{"Hold", "[", 
   RowBox[{
    RowBox[{"y", "^", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"d", "-", "6"}], ")"}], "/", "2"}], ")"}]}], 
    RowBox[{"Y", "^", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"d", "-", "6"}], ")"}], "/", "2"}], ")"}]}], 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"B", "^", "3"}], "+", 
      RowBox[{"c2", " ", 
       RowBox[{"B", "^", "2"}]}], "+", 
      RowBox[{"c1", " ", "B"}], "+", "c0", "+", 
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{"c2", "+", 
          RowBox[{"3", "B"}]}], ")"}], "/", "d2"}], " ", 
       RowBox[{"A", "^", "2"}]}]}], ")"}]}], "]"}]}]], "Input",
 CellChangeTimes->{{3.987570772025235*^9, 3.98757081598271*^9}, 
   3.9875746959363117`*^9},
