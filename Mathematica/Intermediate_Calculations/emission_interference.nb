Cell[BoxData[
 FormBox[
  RowBox[{"Hold", "[", 
   RowBox[{
    SuperscriptBox["y", 
     FractionBox[
      RowBox[{"d", "-", "6"}], "2"]], " ", 
    SuperscriptBox["Y", 
     FractionBox[
      RowBox[{"d", "-", "6"}], "2"]], " ", 
    RowBox[{"(", 
     RowBox[{
      FractionBox[
       RowBox[{
        SuperscriptBox["A", "2"], " ", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"3", " ", "B"}], "+", 
          SubscriptBox["c", "2"]}], ")"}]}], "d2"], "+", 
      SuperscriptBox["B", "3"], "+", 
      RowBox[{
       SuperscriptBox["B", "2"], " ", 
       SubscriptBox["c", "2"]}], "+", 
      RowBox[{"B", " ", 
       SubscriptBox["c", "1"]}], "+", 
      SubscriptBox["c", "0"]}], ")"}]}], "]"}], TraditionalForm]], "Output",
 CellChangeTimes->{
  3.987570816850705*^9, {3.9875746980433283`*^9, 3.9875747071594877`*^9}, 
