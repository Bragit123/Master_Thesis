Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"MrqList", "[", "0", "]"}], "=", 
   RowBox[{
    RowBox[{"FCFAConvert", "[", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"CreateFeynAmp", "[", 
       RowBox[{"diagsQuark", "[", "0", "]"}], "]"}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{"IncomingMomenta", "->", 
       RowBox[{"{", 
        RowBox[{"p1", ",", "p2"}], "}"}]}], ",", "\[IndentingNewLine]", 
      RowBox[{"OutgoingMomenta", "->", 
       RowBox[{"{", 
        RowBox[{"k1", ",", "k", ",", "k2"}], "}"}]}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{"LorentzIndexNames", "->", 
       RowBox[{"{", 
        RowBox[{"\[Mu]", ",", "\[Nu]", ",", "\[Rho]", ",", "\[Sigma]"}], 
        "}"}]}], ",", "\[IndentingNewLine]", 
      RowBox[{"Contract", "->", "False"}], ",", "\[IndentingNewLine]", 
      RowBox[{"List", "->", "True"}], ",", "\[IndentingNewLine]", 
      RowBox[{"SMP", "->", "True"}], ",", "\[IndentingNewLine]", 
      RowBox[{"DropSumOver", "->", "True"}], ",", "\[IndentingNewLine]", 
      RowBox[{"UndoChiralSplittings", "->", "True"}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{"ChangeDimension", "->", "D"}]}], "\[IndentingNewLine]", "]"}], 
    "/.", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"MQU", "[", "quarkGen", "]"}], "->", "0"}], "}"}]}]}], 
  ";"}]], "Input",
