               RowBox[{"mt1", "^", "2"}], "-", 
               RowBox[{"mt2", "^", "2"}]}], ")"}]}]}], ")"}]}], "-", 
         RowBox[{"x", " ", "y"}]}]}], ",", "\[IndentingNewLine]", 
       RowBox[{"A", "->", 
        RowBox[{"2", 
         RowBox[{"Sqrt", "[", "y", "]"}], 
         RowBox[{"Sqrt", "[", "Y", "]"}], 
         RowBox[{"Sqrt", "[", "z", "]"}], 
         RowBox[{"Sqrt", "[", 
          RowBox[{"Xp", " ", "Xm"}], "]"}]}]}]}], "\[IndentingNewLine]", 
