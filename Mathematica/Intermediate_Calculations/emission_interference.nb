Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"yzToYZ", "[", "expr_", "]"}], ":=", 
   RowBox[{"ReplaceAll", "[", 
    RowBox[{"expr", ",", 
     RowBox[{"{", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{
        RowBox[{"1", "-", "z"}], "->", "Z"}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"z", "-", "1"}], "->", 
        RowBox[{"-", "Z"}]}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"1", "-", "y"}], "->", "Y"}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"y", "-", "1"}], "->", 
        RowBox[{"-", "Y"}]}]}], "\[IndentingNewLine]", "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"YZToyz", "[", "expr_", "]"}], ":=", 
   RowBox[{"ReplaceAll", "[", 
    RowBox[{"expr", ",", 
     RowBox[{"{", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"Z", "->", 
        RowBox[{"1", "-", "z"}]}], ",", "\[IndentingNewLine]", 
       RowBox[{"Y", "->", 
        RowBox[{"1", "-", "y"}]}]}], "\[IndentingNewLine]", "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"xyzSimplify", "[", "expr_", "]"}], ":=", 
   RowBox[{"ReplaceAll", "[", 
    RowBox[{"expr", ",", 
     RowBox[{"{", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{
        RowBox[{"y", "+", "Y"}], "->", "1"}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"z", "+", "Z"}], "->", "1"}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{
         RowBox[{"-", "z"}], "+", "Z", "+", "1"}], "->", 
        RowBox[{"2", "Z"}]}]}], "\[IndentingNewLine]", "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"ABToxyz", "[", "expr_", "]"}], ":=", 
   RowBox[{"ReplaceAll", "[", 
    RowBox[{"expr", ",", 
     RowBox[{"{", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"B", "->", 
        RowBox[{
         RowBox[{"z", " ", "Y", 
          RowBox[{"(", 
           RowBox[{"x", "+", 
