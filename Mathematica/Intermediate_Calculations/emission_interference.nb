}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"Hold", "[", 
  RowBox[{
   RowBox[{"B", "^", "3"}], "+", 
   RowBox[{"c2", " ", 
    RowBox[{"B", "^", "2"}]}], "+", 
   RowBox[{"c1", " ", "B"}], "+", "c0", "+", 
   RowBox[{
    RowBox[{
     RowBox[{"(", 
      RowBox[{"c2", "+", 
       RowBox[{"3", "B"}]}], ")"}], "/", "d2"}], " ", 
    RowBox[{"A", "^", "2"}]}]}], "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"%", "//", "FRH"}], "//", "ABToxyz"}], "//", 
   RowBox[{
    RowBox[{"Collect2", "[", 
     RowBox[{"#", ",", 
      RowBox[{"{", 
       RowBox[{"y", ",", "Y"}], "}"}], ",", 
      RowBox[{"Factoring", "->", "FullSimplify"}], ",", 
      RowBox[{"IsolateNames", "->", "KK"}]}], "]"}], "&"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"%", "//", 
    RowBox[{
     RowBox[{"ReplaceAll", "[", 
      RowBox[{"#", ",", 
       RowBox[{"{", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{
          RowBox[{"y", "^", "3"}], "->", 
          RowBox[{
           RowBox[{"y", "^", "2"}], 
           RowBox[{"(", 
            RowBox[{"1", "-", "Y"}], ")"}]}]}], ",", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"Y", "^", "3"}], "->", 
          RowBox[{
           RowBox[{"Y", "^", "2"}], 
           RowBox[{"(", 
            RowBox[{"1", "-", "y"}], ")"}]}]}]}], "\[IndentingNewLine]", 
        "}"}]}], "]"}], "&"}]}], "//", 
   RowBox[{
    RowBox[{"Collect2", "[", 
     RowBox[{"#", ",", 
      RowBox[{"{", 
       RowBox[{"y", ",", "Y"}], "}"}], ",", 
      RowBox[{"Factoring", "->", "FullSimplify"}], ",", 
      RowBox[{"IsolateNames", "->", "KK"}]}], "]"}], "&"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"(", 
   RowBox[{
    RowBox[{"%", "//", 
     RowBox[{
      RowBox[{"ReplaceAll", "[", 
       RowBox[{"#", ",", 
        RowBox[{"{", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{
           RowBox[{"y", "^", "2"}], "->", 
           RowBox[{"y", 
            RowBox[{"(", 
             RowBox[{"1", "-", "Y"}], ")"}]}]}], ",", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"Y", "^", "2"}], "->", 
           RowBox[{"Y", 
            RowBox[{"(", 
             RowBox[{"1", "-", "y"}], ")"}]}]}]}], "\[IndentingNewLine]", 
         "}"}]}], "]"}], "&"}]}], "//", 
    RowBox[{
     RowBox[{"Collect2", "[", 
      RowBox[{"#", ",", 
       RowBox[{"{", 
        RowBox[{"y", ",", "Y"}], "}"}], ",", 
       RowBox[{"Factoring", "->", "FullSimplify"}], ",", 
       RowBox[{"IsolateNames", "->", "KK"}]}], "]"}], "&"}]}], ")"}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"(", 
    RowBox[{
     RowBox[{"%", "/", 
      RowBox[{"(", 
       RowBox[{"y", " ", "Y"}], ")"}]}], "//", 
     RowBox[{
      RowBox[{"Collect2", "[", 
       RowBox[{"#", ",", 
        RowBox[{"{", 
         RowBox[{"y", ",", "Y"}], "}"}], ",", 
        RowBox[{"Factoring", "->", "FullSimplify"}], ",", 
        RowBox[{"IsolateNames", "->", "KK"}]}], "]"}], "&"}]}], ")"}], ";"}], 
  "\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"Note", ":", " ", 
     RowBox[{"Divided", " ", "by", " ", 
      RowBox[{"(", "yY", ")"}]}]}], ",", " ", 
    RowBox[{"so", " ", "we", " ", "multiply", " ", "by", " ", 
     RowBox[{
      RowBox[{"(", "yY", ")"}], "^", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"d", "-", "4"}], ")"}], "/", "2"}], ")"}]}], " ", "instead", 
     " ", "of", " ", 
     RowBox[{
      RowBox[{"(", "yY", ")"}], "^", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"d", "-", "6"}], ")"}], "/", "2"}], ")"}]}], " ", "in", " ", 
     "the", " ", "end"}]}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"yint", "[", "1", "]"}], "=", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       RowBox[{"%", "//", 
        RowBox[{
         RowBox[{"SelectNotFree2", "[", 
          RowBox[{"#", ",", 
           RowBox[{"{", 
            RowBox[{"y", ",", "Y"}], "}"}]}], "]"}], "&"}]}], ")"}], "+", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"%", "//", 
         RowBox[{
          RowBox[{"SelectFree2", "[", 
           RowBox[{"#", ",", 
            RowBox[{"{", 
             RowBox[{"y", ",", "Y"}], "}"}]}], "]"}], "&"}]}], ")"}], 
       RowBox[{"(", 
        RowBox[{"y", "+", "Y"}], ")"}]}]}], "//", "FRH"}], "//", 
    RowBox[{
     RowBox[{"Collect2", "[", 
      RowBox[{"#", ",", 
       RowBox[{"{", 
        RowBox[{"y", ",", "Y", ",", "d2"}], "}"}], ",", 
       RowBox[{"Factoring", "->", "FullSimplify"}], ",", 
       RowBox[{"IsolateNames", "->", "KK"}]}], "]"}], "&"}]}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"yint", "[", "1", "]"}], "=", 
  RowBox[{
