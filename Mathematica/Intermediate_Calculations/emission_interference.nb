Cell[TextData[{
 "We can show (done by hand) that these integrals are all proportional to the \
first one, such that (with ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SuperscriptBox["\[CapitalPhi]", "\[PlusMinus]"], "\[LongEqual]", 
         StyleBox["B", "TI"], "\[PlusMinus]", 
         StyleBox["A", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "\\Phi^\\pm = B \\pm A", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "70cdf410-6643-4a31-b355-f9da58a432b6"],
 ") we have \[LineSeparator]",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["I", "TI"], "0"], "\[LongEqual]", 
         FractionBox[
          RowBox[{"\[CapitalGamma]", "(", 
            RowBox[{
              StyleBox["d", "TI"], "-", "3"}], ")"}], 
          RowBox[{"\[CapitalGamma]", 
            SuperscriptBox[
             RowBox[{"(", 
               RowBox[{
                 RowBox[{"(", 
                   RowBox[{
                    StyleBox["d", "TI"], "-", "2"}], ")"}], "/", "2"}], ")"}],
              "2"]}]], "\[Pi]", 
         SuperscriptBox[
          RowBox[{"(", 
            RowBox[{
              StyleBox["A", "TI"], "/", "2"}], ")"}], 
          RowBox[{
            StyleBox["d", "TI"], "-", "4"}]]}], TraditionalForm], 
     "errors" -> {}, "input" -> 
     "I_0 = \\frac{\\Gamma(d-3)}{\\Gamma((d-2)/2)^2}\\pi (A/2)^{d-4}", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "c35a2582-ffc5-4be3-b9ef-4abc1ef75ce7"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["I", "TI"], "1"], "\[LongEqual]", 
         SubscriptBox[
          StyleBox["I", "TI"], "0"], 
         StyleBox["B", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "I_1 = I_0 B", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "39f77db9-445c-474a-bbb1-200bc95cfd33"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["I", "TI"], "2"], "\[LongEqual]", 
         SubscriptBox[
          StyleBox["I", "TI"], "0"], 
         RowBox[{"(", 
           RowBox[{
             SuperscriptBox[
              StyleBox["B", "TI"], "2"], "+", 
             FractionBox[
              SuperscriptBox[
               StyleBox["A", "TI"], "2"], 
              RowBox[{
                StyleBox["d", "TI"], "-", "2"}]]}], ")"}]}], TraditionalForm],
      "errors" -> {}, "input" -> "I_2 = I_0 (B^2 + \\frac{A^2}{d-2})", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "d2de7538-e193-4ec5-8db3-ae0888929b05"],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["I", "TI"], "3"], "\[LongEqual]", 
         SubscriptBox[
          StyleBox["I", "TI"], "0"], 
         StyleBox["B", "TI"], 
         RowBox[{"(", 
           RowBox[{
             SuperscriptBox[
              StyleBox["B", "TI"], "2"], "+", 
             FractionBox[
              RowBox[{"3", 
                SuperscriptBox[
                 StyleBox["A", "TI"], "2"]}], 
              RowBox[{
                StyleBox["d", "TI"], "-", "2"}]]}], ")"}]}], TraditionalForm],
      "errors" -> {}, "input" -> "I_3 = I_0 B (B^2 + \\frac{3A^2}{d-2})", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "35557964-4ab4-4077-9f2e-db2b7495a1cd"]
}], "Text",
 CellChangeTimes->{{3.987056127420808*^9, 3.987056203106591*^9}, {
  3.987056273318994*^9, 
  3.987056303283449*^9}},ExpressionUUID->"812597cc-9972-4c6c-9c99-\
bf202f9a0b62"]
}, Open  ]]
}, Open  ]],

