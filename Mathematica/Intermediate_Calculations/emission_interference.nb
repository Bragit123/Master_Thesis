            RowBox[{
             RowBox[{"Sqrt", "[", 
              RowBox[{"s", " ", "z"}], "]"}], " ", "mt2"}]}]}], 
          "\[IndentingNewLine]", "}"}]}], "]"}], "&"}]}], "//", 
     "FullSimplify"}], "//", "xyzSimplify"}], "//", 
   RowBox[{
