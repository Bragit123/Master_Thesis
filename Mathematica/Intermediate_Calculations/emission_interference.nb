 RowBox[{
  RowBox[{
   RowBox[{"int", "[", "n_", "]"}], ":=", 
   RowBox[{
    RowBox[{"\[CapitalPhi]", "^", "n"}], " ", 
    RowBox[{
     RowBox[{"(", 
