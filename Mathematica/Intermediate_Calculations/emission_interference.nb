Cell["\<\
Reducing to only p1.k1 and p1.k2, and inserting expressions for pi.k and ki.k.\
\>", "Text",
 CellChangeTimes->{{3.986823548733186*^9, 3.986823673101096*^9}, {
  3.987565629665579*^9, 
  3.9875656316845903`*^9}},ExpressionUUID->"06af6718-47e0-416a-acc7-\
