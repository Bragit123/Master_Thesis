Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"yzToYZ", "[", "expr_", "]"}], ":=", 
   RowBox[{"ReplaceAll", "[", 
    RowBox[{"expr", ",", 
     RowBox[{"{", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{
        RowBox[{"1", "-", "z"}], "->", "Z"}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"z", "-", "1"}], "->", 
        RowBox[{"-", "Z"}]}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"1", "-", "y"}], "->", "Y"}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"y", "-", "1"}], "->", 
        RowBox[{"-", "Y"}]}]}], "\[IndentingNewLine]", "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"YZToyz", "[", "expr_", "]"}], ":=", 
   RowBox[{"ReplaceAll", "[", 
    RowBox[{"expr", ",", 
     RowBox[{"{", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"Z", "->", 
        RowBox[{"1", "-", "z"}]}], ",", "\[IndentingNewLine]", 
       RowBox[{"Y", "->", 
        RowBox[{"1", "-", "y"}]}]}], "\[IndentingNewLine]", "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"xyzSimplify", "[", "expr_", "]"}], ":=", 
   RowBox[{"ReplaceAll", "[", 
    RowBox[{"expr", ",", 
     RowBox[{"{", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{
        RowBox[{"y", "+", "Y"}], "->", "1"}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"z", "+", "Z"}], "->", "1"}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{
         RowBox[{"-", "z"}], "+", "Z", "+", "1"}], "->", 
        RowBox[{"2", "Z"}]}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"1", "-", "z"}], "->", "Z"}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"z", "-", "1"}], "->", 
        RowBox[{"-", "Z"}]}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"1", "-", "Z"}], "->", "z"}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"Z", "-", "1"}], "->", 
        RowBox[{"-", "z"}]}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"1", "-", "y"}], "->", "Y"}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"y", "-", "1"}], "->", 
        RowBox[{"-", "Y"}]}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"1", "-", "Y"}], "->", "y"}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"Y", "-", "1"}], "->", 
        RowBox[{"-", "y"}]}]}], "\[IndentingNewLine]", "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"ABToxyz", "[", "expr_", "]"}], ":=", 
   RowBox[{"ReplaceAll", "[", 
    RowBox[{"expr", ",", 
     RowBox[{"{", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"B", "->", 
        RowBox[{
         RowBox[{"z", " ", "Y", 
          RowBox[{"(", 
           RowBox[{"x", "+", 
            RowBox[{"2", 
             RowBox[{"(", 
              RowBox[{
               RowBox[{"mt1", "^", "2"}], "-", 
               RowBox[{"mt2", "^", "2"}]}], ")"}]}]}], ")"}]}], "-", 
         RowBox[{"x", " ", "y"}]}]}], ",", "\[IndentingNewLine]", 
       RowBox[{"A", "->", 
        RowBox[{"2", 
         RowBox[{"Sqrt", "[", "y", "]"}], 
         RowBox[{"Sqrt", "[", "Y", "]"}], 
         RowBox[{"Sqrt", "[", "z", "]"}], 
         RowBox[{"Sqrt", "[", 
          RowBox[{"Xp", " ", "Xm"}], "]"}]}]}]}], "\[IndentingNewLine]", 
      "}"}]}], "]"}]}], ";"}]}], "Input",
