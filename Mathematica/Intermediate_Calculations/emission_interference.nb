              "FullSimplify"}], "//", "pikikToxyz"}], "//", "FCE"}], "//", 
           RowBox[{
            RowBox[{"ReplaceAll", "[", 
             RowBox[{"#", ",", 
              RowBox[{"{", "\[IndentingNewLine]", 
               RowBox[{
                RowBox[{"SPD", "[", 
                 RowBox[{"k1", ",", "k2"}], "]"}], "->", 
                RowBox[{"(", 
                 RowBox[{
                  RowBox[{"s", " ", "z"}], "-", 
                  RowBox[{"m1", "^", "2"}], "-", 
                  RowBox[{"m2", "^", "2"}]}], ")"}]}], "\[IndentingNewLine]", 
               "}"}]}], "]"}], "&"}]}], "//", "FullSimplify"}], "//", "FRH"}],
         "//", "p1kiToyzPhi"}], "//", "FullSimplify"}], "//", 
      RowBox[{
       RowBox[{"ReplaceAll", "[", 
        RowBox[{"#", ",", 
         RowBox[{"{", "\[IndentingNewLine]", 
