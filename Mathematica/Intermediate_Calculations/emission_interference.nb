Cell[BoxData[{
 RowBox[{
  RowBox[{
  "description", "=", 
   "\"\<Interference between initial- and final-state radiation.\>\""}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"If", "[", " ", 
   RowBox[{
    RowBox[{"$FrontEnd", " ", "===", " ", "Null"}], ",", "\n", "\t", 
