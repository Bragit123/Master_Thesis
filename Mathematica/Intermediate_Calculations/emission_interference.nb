Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"top1ki", "[", "expr_", "]"}], ":=", 
   RowBox[{"ReplaceAll", "[", 
    RowBox[{
     RowBox[{"FCE", "[", "expr", "]"}], ",", 
     RowBox[{"{", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{
        RowBox[{"SPD", "[", 
         RowBox[{"p2", ",", "k1"}], "]"}], "->", 
        RowBox[{
         RowBox[{"m1", "^", "2"}], "+", 
         RowBox[{"SPD", "[", 
          RowBox[{"k1", ",", "k2"}], "]"}], "+", 
         RowBox[{"SPD", "[", 
          RowBox[{"k1", ",", "k"}], "]"}], "-", 
         RowBox[{"SPD", "[", 
          RowBox[{"p1", ",", "k1"}], "]"}]}]}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"SPD", "[", 
         RowBox[{"p2", ",", "k2"}], "]"}], "->", 
        RowBox[{
         RowBox[{"m2", "^", "2"}], "+", 
         RowBox[{"SPD", "[", 
          RowBox[{"k1", ",", "k2"}], "]"}], "+", 
         RowBox[{"SPD", "[", 
          RowBox[{"k2", ",", "k"}], "]"}], "-", 
         RowBox[{"SPD", "[", 
          RowBox[{"p1", ",", "k2"}], "]"}]}]}]}], "\[IndentingNewLine]", 
      "}"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"pikikToxyz", "[", "expr_", "]"}], ":=", 
   RowBox[{"ReplaceAll", "[", 
    RowBox[{"expr", ",", 
     RowBox[{"{", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{
        RowBox[{"SPD", "[", 
         RowBox[{"p1", ",", "k"}], "]"}], "->", 
        RowBox[{
         RowBox[{"s", "/", "2"}], "Z", " ", "Y"}]}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"SPD", "[", 
         RowBox[{"p2", ",", "k"}], "]"}], "->", 
        RowBox[{
         RowBox[{"s", "/", "2"}], "Z", " ", "y"}]}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"SPD", "[", 
         RowBox[{"k1", ",", "k"}], "]"}], "->", 
        RowBox[{
         RowBox[{"s", "/", "4"}], "Z", " ", 
         RowBox[{"(", 
          RowBox[{"1", "-", "x"}], ")"}]}]}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"SPD", "[", 
         RowBox[{"k2", ",", "k"}], "]"}], "->", 
        RowBox[{
         RowBox[{"s", "/", "4"}], "Z", " ", 
         RowBox[{"(", 
          RowBox[{"1", "+", "x"}], ")"}]}]}]}], "\[IndentingNewLine]", 
      "}"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
