            SuperscriptBox[
             RowBox[{"(", 
               RowBox[{"1", "+", 
                 StyleBox["x", "TI"]}], ")"}], "2"], 
            SuperscriptBox[
             RowBox[{"(", 
               RowBox[{"1", "-", 
                 StyleBox["x", "TI"]}], ")"}], "2"]}]], "ln", 
         RowBox[{"[", 
           RowBox[{
             RowBox[{"(", 
               RowBox[{
                 SuperscriptBox[
                  StyleBox["x", "TI"], "+"], "-", 
                 StyleBox["x", "TI"]}], ")"}], "(", 
             RowBox[{
               StyleBox["x", "TI"], "-", 
               SuperscriptBox[
                StyleBox["x", "TI"], "-"]}], ")"}], "]"}]}], TraditionalForm],
      "errors" -> {}, "input" -> 
     "I_2 = \\int_{x^-}^{x^+} dx \
\\frac{(x^+-x)(x-x^-)}{(1+x)^2(1-x)^2}\\ln[(x^+-x)(x-x^-)]", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "85b1fc3d-146d-4ca7-a94a-d6df2562ea55"],
