          StyleBox["I", "TI"], "2"], "\[LongEqual]", 
         SubsuperscriptBox["\[Integral]", 
          SuperscriptBox[
           StyleBox["x", "TI"], "-"], 
          SuperscriptBox[
           StyleBox["x", "TI"], "+"]], 
         StyleBox["d", "TI"], 
         StyleBox["x", "TI"], 
         FractionBox[
          RowBox[{
            RowBox[{"(", 
              RowBox[{
                SuperscriptBox[
                 StyleBox["x", "TI"], "+"], "-", 
                StyleBox["x", "TI"]}], ")"}], "(", 
