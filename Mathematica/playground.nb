Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{"2", " ", 
    SuperscriptBox["m", "2"], " ", 
    FormBox[
     TagBox[
      FormBox[
       RowBox[{
        SubscriptBox["\<\"B\"\>", "\<\"0\"\>"], "(", 
        RowBox[{"0", ",", "0", ",", 
         SuperscriptBox["m", "2"]}], ")"}],
       TraditionalForm],
      HoldForm],
     TraditionalForm]}], "-", 
   FormBox[
    TagBox[
     FormBox[
      RowBox[{
       SubscriptBox["\<\"A\"\>", "\<\"0\"\>"], "(", 
       SuperscriptBox["m", "2"], ")"}],
      TraditionalForm],
     HoldForm],
    TraditionalForm]}], TraditionalForm]], "Output",
 CellChangeTimes->{3.9811891906080227`*^9},
 CellLabel->"Out[67]=",ExpressionUUID->"b519a0e7-4694-4a58-a7a1-04ff94480b9e"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"self", "[", "2", "]"}], "=", 
  RowBox[{
   RowBox[{
    RowBox[{"self", "[", "1", "]"}], "//", "PaXEvaluateUVIRSplit"}], "//", 
   RowBox[{
    RowBox[{"Collect2", "[", 
     RowBox[{"#", ",", 
      RowBox[{"{", 
       RowBox[{"EpsilonIR", ",", "EpsilonUV"}], "}"}], ",", 
      RowBox[{"Factoring", "->", "FullSimplify"}]}], "]"}], 
    "&"}]}]}]], "Input",
 CellChangeTimes->{{3.9811891930307302`*^9, 3.981189215383847*^9}},
 CellLabel->"In[68]:=",ExpressionUUID->"571f36ed-7122-4370-aacd-0d9ad9303829"],

Cell[BoxData[
 FormBox[
  RowBox[{
   FractionBox[
    SuperscriptBox["m", "2"], 
    SubscriptBox["\[CurlyEpsilon]", "UV"]], "-", 
   RowBox[{
    SuperscriptBox["m", "2"], " ", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", 
       RowBox[{"log", "(", 
        FractionBox[
         SuperscriptBox["\[Mu]", "2"], 
         SuperscriptBox["m", "2"]], ")"}]}], "+", 
      TagBox["\[DoubledGamma]",
       Function[{}, EulerGamma]], "-", "1", "+", 
      RowBox[{"log", "(", "\[Pi]", ")"}]}], ")"}]}]}], 
  TraditionalForm]], "Output",
 CellChangeTimes->{3.981189215683235*^9},
 CellLabel->"Out[68]=",ExpressionUUID->"9e429d49-955c-489a-aaae-1df33614ac38"]
}, Open  ]]
}, Open  ]],

