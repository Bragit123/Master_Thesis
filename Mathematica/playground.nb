 CellChangeTimes->{{3.981195403529282*^9, 
  3.981195418260029*^9}},ExpressionUUID->"7f8f7451-00dd-4015-8fb2-\
13a07fde8f6e"],

Cell[BoxData[
 RowBox[{
  RowBox[{"FCClearScalarProducts", "[", "]"}], ";"}]], "Input",
 CellChangeTimes->{{3.981195432007214*^9, 3.981195433957715*^9}},
 CellLabel->"In[69]:=",ExpressionUUID->"906d88f1-5d67-4e6e-891e-13aac74b28a0"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"(", 
   RowBox[{
    RowBox[{"x", 
     RowBox[{"(", 
      RowBox[{"1", "-", "x"}], ")"}], 
     RowBox[{"SPD", "[", "p", "]"}]}], "+", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{"1", "-", "x"}], ")"}], 
     RowBox[{"m1", "^", "2"}]}], "+", 
    RowBox[{"x", " ", 
     RowBox[{"m2", "^", "2"}]}]}], ")"}], 
  RowBox[{"Log", "[", 
   RowBox[{
    RowBox[{"x", 
     RowBox[{"(", 
      RowBox[{"1", "-", "x"}], ")"}], 
     RowBox[{"SPD", "[", "p", "]"}]}], "+", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{"1", "-", "x"}], ")"}], 
     RowBox[{"m1", "^", "2"}]}], "+", 
    RowBox[{"x", " ", 
     RowBox[{"m2", "^", "2"}]}]}], "]"}]}], "\[IndentingNewLine]", 
 RowBox[{"Integrate", "[", 
  RowBox[{"%", ",", 
   RowBox[{"{", 
    RowBox[{"x", ",", "0", ",", "1"}], "}"}], ",", 
   RowBox[{"Assumptions", "->", 
    RowBox[{
     RowBox[{
      RowBox[{"SPD", "[", "p", "]"}], "\[Element]", "Reals"}], "&&", 
     RowBox[{"m1", "\[Element]", "PositiveReals"}], "&&", 
     RowBox[{"m2", "\[Element]", "PositiveReals"}]}]}]}], "]"}]}], "Input",
 CellChangeTimes->{{3.981195421808606*^9, 3.981195525950835*^9}},
 CellLabel->"In[73]:=",ExpressionUUID->"4300ad34-f527-41ff-84f7-692a53945d4c"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{"(", 
    RowBox[{
     RowBox[{
      SubsuperscriptBox["m", "1", "2"], " ", 
      RowBox[{"(", 
       RowBox[{"1", "-", "x"}], ")"}]}], "+", 
     RowBox[{
      SubsuperscriptBox["m", "2", "2"], " ", "x"}], "+", 
     RowBox[{
      FormBox[
       SuperscriptBox[
        FormBox[
         FormBox["p",
          TraditionalForm],
         TraditionalForm], "2"],
       TraditionalForm], " ", 
      RowBox[{"(", 
       RowBox[{"1", "-", "x"}], ")"}], " ", "x"}]}], ")"}], " ", 
   RowBox[{"log", "(", 
    RowBox[{
     RowBox[{
      SubsuperscriptBox["m", "1", "2"], " ", 
      RowBox[{"(", 
       RowBox[{"1", "-", "x"}], ")"}]}], "+", 
     RowBox[{
      SubsuperscriptBox["m", "2", "2"], " ", "x"}], "+", 
     RowBox[{
      FormBox[
       SuperscriptBox[
        FormBox[
         FormBox["p",
          TraditionalForm],
         TraditionalForm], "2"],
       TraditionalForm], " ", 
      RowBox[{"(", 
       RowBox[{"1", "-", "x"}], ")"}], " ", "x"}]}], ")"}]}], 
  TraditionalForm]], "Output",
 CellChangeTimes->{
  3.981195460263548*^9, {3.981195519292131*^9, 3.981195526316063*^9}},
 CellLabel->"Out[73]=",ExpressionUUID->"2c9fd775-d957-4996-afc8-3a361efe1c61"]
