            SubscriptBox["\[Theta]", "W"], ")"}], ")"}], " ", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"sin", "("}], 
            SubscriptBox["\[Theta]", "W"], ")"}], ")"}], " ", 
          RowBox[{"(", 
           InterpretationBox[
            RowBox[{
             SuperscriptBox[
              RowBox[{
               FormBox["\<\"(\"\>",
                TraditionalForm], 
               FormBox[
                FormBox[
                 RowBox[{
                  FormBox[
                   SubscriptBox["k", "1"],
