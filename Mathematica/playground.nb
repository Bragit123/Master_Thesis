    RowBox[{
     RowBox[{"(", 
      RowBox[{"1", "-", "x"}], ")"}], 
     RowBox[{"m1", "^", "2"}]}], "+", 
    RowBox[{"x", " ", 
     RowBox[{"m2", "^", "2"}]}]}], "]"}]}], "\[IndentingNewLine]", 
 RowBox[{"Integrate", "[", 
  RowBox[{"%", ",", 
   RowBox[{"{", 
    RowBox[{"x", ",", "0", ",", "1"}], "}"}], ",", 
   RowBox[{"Assumptions", "->", 
    RowBox[{
     RowBox[{
      RowBox[{"SPD", "[", "p", "]"}], "\[Element]", "Reals"}], "&&", 
     RowBox[{"m1", "\[Element]", "PositiveReals"}], "&&", 
