                  FormBox[
                   SubscriptBox["k", "2"],
                   TraditionalForm]}],
                 TraditionalForm],
                TraditionalForm], 
               FormBox["\<\")\"\>",
                TraditionalForm]}], "2"], "\[InvisibleSpace]", "\<\"-\"\>", 
             "\[InvisibleSpace]", 
             SubsuperscriptBox["m", "Z", "2"]}],
            SequenceForm[
             FeynCalc`Pair[
              FeynCalc`Momentum[PrettyNotation`k1 + PrettyNotation`k2, D], 
              FeynCalc`Momentum[PrettyNotation`k1 + PrettyNotation`k2, D]], 
             "-", FeynCalc`SMP["m_Z"]^2],
            Editable->False], ")"}]}], ")"}]}], ")"}]}],
