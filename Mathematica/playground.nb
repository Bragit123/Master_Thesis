 CellChangeTimes->{{3.981189093918585*^9, 
  3.981189097049477*^9}},ExpressionUUID->"3f5ae4a6-365e-4ca1-bf5d-\
e078904dc521"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"FCClearScalarProducts", "[", "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"SPD", "[", "p", "]"}], "=", 
   RowBox[{"m", "^", "2"}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.9811891203076572`*^9, 
  3.9811891269266787`*^9}},ExpressionUUID->"fd25da0b-7271-4fc0-a341-\
eea675a68b25"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"self", "[", "0", "]"}], "=", 
  RowBox[{
   RowBox[{"1", "/", 
    RowBox[{"(", 
     RowBox[{"I", " ", 
      RowBox[{"Pi", "^", "2"}]}], ")"}]}], 
   RowBox[{"SPD", "[", 
    RowBox[{"k", "+", 
     RowBox[{"2", "p"}]}], "]"}], 
   RowBox[{"FAD", "[", 
    RowBox[{"k", ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"k", "+", "p"}], ",", "m"}], "}"}]}], "]"}]}]}]], "Input",
 CellChangeTimes->{{3.981189102085734*^9, 3.9811891745867777`*^9}},
 CellLabel->"In[66]:=",ExpressionUUID->"0febf8bb-3ecd-413f-b29c-1277e5884567"],

Cell[BoxData[
 FormBox[
  RowBox[{"-", 
   FractionBox[
    RowBox[{"\[ImaginaryI]", " ", 
     FormBox[
      SuperscriptBox[
       RowBox[{
        FormBox["\<\"(\"\>",
         TraditionalForm], 
        FormBox[
         FormBox[
          RowBox[{
           FormBox["k",
            TraditionalForm], "+", 
           RowBox[{"2", " ", 
            FormBox["p",
             TraditionalForm]}]}],
          TraditionalForm],
         TraditionalForm], 
        FormBox["\<\")\"\>",
         TraditionalForm]}], "2"],
      TraditionalForm]}], 
    RowBox[{
     SuperscriptBox["\[Pi]", "2"], " ", 
     RowBox[{
      InterpretationBox[
       SuperscriptBox[
        FormBox[
         FormBox["k",
          TraditionalForm],
         TraditionalForm], "2"],
       SequenceForm[
        FeynCalc`Pair[
         FeynCalc`Momentum[$CellContext`k, D], 
         FeynCalc`Momentum[$CellContext`k, D]]],
       Editable->False], ".", 
      RowBox[{"(", 
       InterpretationBox[
        RowBox[{
         SuperscriptBox[
          RowBox[{
           FormBox["\<\"(\"\>",
            TraditionalForm], 
           FormBox[
            FormBox[
             RowBox[{
              FormBox["k",
               TraditionalForm], "+", 
              FormBox["p",
               TraditionalForm]}],
             TraditionalForm],
            TraditionalForm], 
           FormBox["\<\")\"\>",
            TraditionalForm]}], "2"], "\[InvisibleSpace]", "\<\"-\"\>", 
         "\[InvisibleSpace]", 
         SuperscriptBox["m", "2"]}],
        SequenceForm[
         FeynCalc`Pair[
          FeynCalc`Momentum[$CellContext`k + $CellContext`p, D], 
          FeynCalc`Momentum[$CellContext`k + $CellContext`p, D]], 
         "-", $CellContext`m^2],
        Editable->False], ")"}]}]}]]}], TraditionalForm]], "Output",
 CellChangeTimes->{{3.9811891606648817`*^9, 3.98118917551414*^9}},
 CellLabel->"Out[66]=",ExpressionUUID->"c750021e-66bb-45d9-8d56-a3af13ae7583"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"self", "[", "1", "]"}], "=", 
  RowBox[{
   RowBox[{"self", "[", "0", "]"}], "//", 
   RowBox[{
    RowBox[{"TID", "[", 
     RowBox[{"#", ",", "k", ",", 
      RowBox[{"ToPaVe", "->", "True"}]}], "]"}], "&"}]}]}]], "Input",
