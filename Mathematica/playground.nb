Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"SPD", "[", 
   RowBox[{"k", "+", 
    RowBox[{"2", "p"}]}], "]"}], 
  RowBox[{
   RowBox[{"FAD", "[", 
    RowBox[{"k", ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"k", "+", "p"}], ",", "m"}], "}"}]}], "]"}], "/", 
   RowBox[{"(", 
    RowBox[{"I", " ", 
     RowBox[{"Pi", "^", "2"}]}], ")"}]}]}], "\[IndentingNewLine]", 
 RowBox[{"%", "//", 
  RowBox[{
   RowBox[{"TID", "[", 
    RowBox[{"#", ",", "k", ",", 
     RowBox[{"ToPaVe", "->", "True"}]}], "]"}], 
   "&"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"%", "//", 
   RowBox[{
    RowBox[{"PaXEvaluateUVIRSplit", "[", 
     RowBox[{"#", ",", 
      RowBox[{"PaXImplicitPrefactor", "->", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"2", "Pi"}], ")"}], "^", 
        RowBox[{"(", 
